{
  "info": {
    "name": "Drug Track & Trace API",
    "description": "Complete API collection for Drug Track & Trace System with role-based authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@customer.com\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Register Manufacturer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@manufacturer.com\",\n  \"password\": \"password123\",\n  \"role\": \"manufacturer\",\n  \"company_name\": \"HealthCorp Ltd\",\n  \"license_number\": \"LIC-2024-999\",\n  \"address\": \"123 Medical Street, City\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@test.com\",\n  \"password\": \"customer123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login Manufacturer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manufacturer@pharma.com\",\n  \"password\": \"manu123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-token"]
            }
          }
        }
      ]
    },
    {
      "name": "Manufacturer",
      "item": [
        {
          "name": "Generate Drug Batch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"drug_name\": \"Aspirin 100mg\",\n  \"manufacturer\": \"PharmaCorp Ltd\",\n  \"batch_number\": \"BATCH999\",\n  \"quantity\": 50,\n  \"expiry_date\": \"2025-12-31\",\n  \"manufacturing_date\": \"2024-01-15\",\n  \"description\": \"Pain relief medication\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/manufacturer/drug/generate",
              "host": ["{{baseUrl}}"],
              "path": ["manufacturer", "drug", "generate"]
            }
          }
        },
        {
          "name": "Get Manufacturer Drugs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/manufacturer/drugs?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["manufacturer", "drugs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Get Manufacturer Batches",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/manufacturer/batches",
              "host": ["{{baseUrl}}"],
              "path": ["manufacturer", "batches"]
            }
          }
        },
        {
          "name": "Recall Batch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batch_number\": \"BATCH999\",\n  \"reason\": \"Quality control issue detected\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/manufacturer/recall",
              "host": ["{{baseUrl}}"],
              "path": ["manufacturer", "recall"]
            }
          }
        },
        {
          "name": "Get Batch Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/manufacturer/batch/BATCH001",
              "host": ["{{baseUrl}}"],
              "path": ["manufacturer", "batch", "BATCH001"]
            }
          }
        },
        {
          "name": "Get Manufacturer Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/manufacturer/stats",
              "host": ["{{baseUrl}}"],
              "path": ["manufacturer", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "Verify Drug",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/customer/verify/PARECE-BATCH001-202401-0001",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "verify", "PARECE-BATCH001-202401-0001"]
            }
          }
        },
        {
          "name": "Get Scan History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/customer/history?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "history"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Submit Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serial_number\": \"FAKE-SERIAL-123\",\n  \"issue_type\": \"fake\",\n  \"issue_description\": \"This drug appears to be counterfeit. The packaging looks suspicious and the QR code is not registered.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/customer/report",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "report"]
            }
          }
        },
        {
          "name": "Get User Reports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/customer/reports?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "reports"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Reports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/reports?page=1&limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reports"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            }
          }
        },
        {
          "name": "Update Report Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"admin_notes\": \"Investigated and confirmed as counterfeit. Manufacturer notified.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/report/:reportId/status",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "report", ":reportId", "status"],
              "variable": [
                {
                  "key": "reportId",
                  "value": "report_id_here"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Drugs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/drugs?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "drugs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Scans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/scans?page=1&limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "scans"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            }
          }
        },
        {
          "name": "Get System Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/stats",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    }
  ]
}
